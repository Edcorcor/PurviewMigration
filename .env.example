# Copy this to .env and fill in your values
# NEVER commit .env to git

# Azure Authentication
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Purview Configuration
# Leave these empty for auto-discovery
PURVIEW_ACCOUNT_NAMES=          # Optional: comma-separated list of account names
PURVIEW_AUTO_DISCOVER=true

# Fabric Workspace
FABRIC_WORKSPACE_ID=            # Optional: auto-create if not provided
FABRIC_WORKSPACE_NAME=PurviewAuditWorkspace
FABRIC_CAPACITY_ID=             # Optional: required if your tenant needs explicit capacity assignment
FABRIC_ENVIRONMENT_NAME=PurviewAuditSpark
FABRIC_NOTEBOOK_NAME=00-Setup
FABRIC_PUBLIC_CLIENT_ID=        # Required for device-code Fabric API login unless using service principal auth

# Key Vault
KEY_VAULT_NAME=your-keyvault-name
CHECK_FABRIC_VAULT_CONNECTION=true

# Optional: Service Principal credentials (for non-interactive auth)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY_HOST=https://login.microsoftonline.com/

# Spark Configuration
SPARK_MEMORY=4g
SPARK_CORES=4

# Output Configuration
OUTPUT_DESTINATION=fabric        # Options: fabric, local, adls
OUTPUT_DATA_FORMAT=parquet
OUTPUT_OVERWRITE=true

# Logging
LOGGING_LEVEL=INFO
LOGGING_FORMAT=json
